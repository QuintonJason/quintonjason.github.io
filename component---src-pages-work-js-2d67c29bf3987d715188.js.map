module.exports = [{"title":"Pine Design System","summary":"Kajabi's multi-platform design system powering consistent, accessible product experiences across 6 product teams and 40+ engineers. My work helps Pine operate as product infrastructure: web components, semantic tokens, accessibility standards, governance, documentation, and shared developer workflows.","role":"Senior Design Engineer","status":"Design system infrastructure","links":[{"label":"View Pine Design System","url":"https://pine-design-system.netlify.app/"},{"label":"View Pine MCP","url":"#pine-mcp"}],"topics":["Design Systems","Web Components","Design Tokens","Accessibility","Governance","Developer Experience"]},{"title":"Pine MCP","summary":"An MCP integration that exposes Pine design system knowledge to AI assistants so generated code can follow established components, tokens, accessibility requirements, and implementation standards. The work extends design system adoption into the moment AI-assisted code is being produced.","role":"AI-Assisted Development","status":"Design system knowledge workflow","links":[{"label":"View Pine MCP case study","url":"/work/pine-mcp/"},{"label":"Read the article","url":"https://medium.com/@quintonjasonjr/teaching-ai-our-design-system-d9788fe96c8e"}],"topics":["AI-Assisted Development","MCP","Design Systems","Developer Experience","Frontend Architecture"]},{"title":"Design tokens and theming","summary":"Defined and operationalized semantic tokens for color, typography, spacing, and motion so design decisions could travel cleanly from Figma into production code. The goal is fewer one-off choices, clearer system contracts, and less design-to-code drift.","role":"Frontend Architecture","status":"System infrastructure","links":[{"label":"Figma Variables vs Tokens Studio","url":"https://dev.to/quintonjason/figma-variables-vs-tokens-studio-why-both-matter-2md7"}],"topics":["Design Tokens","Theming","Figma","CSS"]},{"title":"Accessible component standards","summary":"Established accessibility and semantic standards at the system level so new product work starts from a stronger baseline. This includes accessible patterns, HTML semantics, WCAG-minded defaults, and guidance for engineers and designers using the system.","role":"Accessibility / UI Engineering","status":"Quality foundation","links":[{"label":"Read writing","url":"/writing/"}],"topics":["Accessibility","WCAG","Semantic HTML","Design Systems"]},{"title":"Developer experience and system adoption","summary":"Improved component ergonomics, documentation, handoff workflows, and contribution paths so design system work is easier to trust and use. The focus is not just documenting the system, but making it adoptable inside busy product teams.","role":"Developer Tooling","status":"Adoption work","links":[{"label":"Systematically Not Following the Design System Is a System","url":"https://dev.to/quintonjason/systematically-not-following-the-design-system-is-a-system-31dn"}],"topics":["Documentation","DX","Contribution Models","Team Workflows"]},{"title":"Web UX education","summary":"Teaching and mentoring students in web design, interaction design, front-end development, accessibility, responsive design, and systems thinking. Teaching keeps the fundamentals sharp and reinforces the mental models behind strong UI architecture.","role":"Instructor","status":"Teaching","links":[{"label":"LSU faculty profile","url":"https://design.lsu.edu/faculty/jason-quinton/"}],"topics":["Teaching","UX","HTML","CSS","JavaScript"]}]


