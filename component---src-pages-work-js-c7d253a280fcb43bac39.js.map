module.exports = [{"title":"Core product design system","summary":"Led the design, implementation, and evolution of a core design system supporting multiple product surfaces and engineering teams. The work centered on durable component APIs, system constraints, contribution models, and practical adoption across real product flows.","role":"Senior Design Engineer","status":"System leadership","links":[{"label":"View Pine Design System","url":"https://pine-design-system.netlify.app/"},{"label":"Read design system writing","url":"/writing/"}],"topics":["Design Systems","Component APIs","Governance","Product UI"]},{"title":"Design tokens and theming","summary":"Defined and operationalized semantic tokens for color, typography, spacing, and motion so design decisions could travel cleanly from Figma into production code. The goal: fewer one-off choices, clearer system contracts, and less design-to-code drift.","role":"Frontend Architecture","status":"System infrastructure","links":[{"label":"Figma Variables vs Tokens Studio","url":"https://dev.to/quintonjason/figma-variables-vs-tokens-studio-why-both-matter-2md7"}],"topics":["Design Tokens","Theming","Figma","CSS"]},{"title":"Accessible component standards","summary":"Established accessibility and semantic standards at the system level, improving the baseline quality of new and existing features. This included accessible patterns, HTML semantics, WCAG-minded defaults, and guidance for engineers and designers using the system.","role":"Accessibility / UI Engineering","status":"Quality foundation","links":[{"label":"Read writing","url":"/writing/"}],"topics":["Accessibility","WCAG","Semantic HTML","Design Systems"]},{"title":"Developer experience and system adoption","summary":"Improved component ergonomics, documentation, handoff workflows, and contribution paths so design system work was easier to trust and use. The focus was not just documenting the system, but making it adoptable inside busy product teams.","role":"Developer Tooling","status":"Adoption work","links":[{"label":"Systematically Not Following the Design System Is a System","url":"https://dev.to/quintonjason/systematically-not-following-the-design-system-is-a-system-31dn"}],"topics":["Documentation","DX","Contribution Models","Team Workflows"]},{"title":"AI-native design system workflows","summary":"Exploring how teams can teach AI tools the language, constraints, decision history, and implementation rules of a design system instead of treating AI as a generic autocomplete layer.","role":"AI / Systems Thinking","status":"Recent writing","links":[{"label":"Teaching AI Our Design System","url":"https://medium.com/@quintonjasonjr/teaching-ai-our-design-system-d9788fe96c8e"}],"topics":["AI","Design Systems","Context","Documentation"]},{"title":"Web UX education","summary":"Teaching and mentoring students in web design, interaction design, front-end development, accessibility, responsive design, and systems thinking. Teaching keeps the fundamentals sharp and reinforces the mental models behind strong UI architecture.","role":"Instructor","status":"Teaching","links":[{"label":"LSU faculty profile","url":"https://design.lsu.edu/faculty/jason-quinton/"}],"topics":["Teaching","UX","HTML","CSS","JavaScript"]}]


